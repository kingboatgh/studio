rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper function to check for admin privileges
    function isAdmin() {
      // Check if a document for the user exists in the 'admins' collection.
      return exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Districts can be read by anyone, but only written by admins.
    match /districts/{districtId} {
      allow read: if true;
      allow write: if isAdmin();
      
      // Personnel can be read by anyone.
      // Writes (create, update, delete) are restricted to admins.
      match /personnel/{personnelId} {
        allow read: if true;
        allow write: if isAdmin();

        // Submissions can be read by anyone.
        // Any authenticated user (admin or desk officer) can create submissions.
        match /submissions/{submissionId} {
          allow read: if true;
          allow create: if request.auth != null;
          allow update, delete: if isAdmin();
        }
      }
      
      // Users collection can be read by anyone, written by admins.
      match /users/{userId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }
    
    // The admins collection can be read by anyone (for client-side checks)
    // but only written to by other admins.
    match /admins/{userId} {
        allow read: if true;
        allow write: if isAdmin();
    }
  }
}
