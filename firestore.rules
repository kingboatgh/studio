rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper function to check for admin privileges
    function isAdmin() {
      return exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Districts can be read by any authenticated user, but only written by admins.
    match /districts/{districtId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
      
      // Personnel can be read by any authenticated user.
      // Writes (create, update, delete) are restricted to admins.
      match /personnel/{personnelId} {
        allow read: if request.auth != null;
        allow write: if isAdmin();

        // Submissions can be read by any authenticated user.
        // Any authenticated user (admin or desk officer) can create submissions.
        match /submissions/{submissionId} {
          allow read: if request.auth != null;
          allow create: if request.auth != null;
          allow update, delete: if isAdmin();
        }
      }
      
      // Users collection can be read by authenticated users, written by admins.
      match /users/{userId} {
        allow read: if request.auth != null;
        allow write: if isAdmin();
      }
    }
    
    // The admins collection can only be modified by other admins.
    match /admins/{userId} {
        allow read: if request.auth != null;
        allow write: if isAdmin();
    }
  }
}
