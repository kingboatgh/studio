rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check for admin privileges
    function isAdmin() {
      return exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    // Admins collection can only be read to check for admin status
    match /admins/{userId} {
      allow read: if request.auth != null;
      allow write: if false; // Nobody can write to the admins collection directly
    }

    // Districts can be read by any authenticated user, but only written by admins
    match /districts/{districtId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
      
      // Personnel records can be read by any authenticated user, but only written by admins
      match /personnel/{personnelId} {
        allow read: if request.auth != null;
        allow write: if isAdmin();
        
        // Submissions can be created by any authenticated user, but only updated/deleted by admins
        match /submissions/{submissionId} {
          allow read: if request.auth != null;
          allow create: if request.auth != null;
          allow update, delete: if isAdmin();
        }
      }
    }
  }
}
